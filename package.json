{
  "name": "ai-code-coach",
  "version": "1.0.0",
  "description": "AI-powered personal programming coach — analyzes your code and tracks your growth",
  "main": "dist/index.js",
  "bin": {
    "ai-coach": "./dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest --verbose",
    "test:watch": "jest --watch",
    "prepublishOnly": "npm test && npm run build"
  },
  "keywords": [
    "code-review",
    "ai",
    "claude",
    "deepseek",
    "kimi",
    "code-quality",
    "cli",
    "developer-tools"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lsc-261013/ai-code-coach"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/tests"],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    }
  },
  "dependencies": {
    "commander": "^12.1.0",
    "@anthropic-ai/sdk": "^0.32.1",
    "openai": "^4.73.0",
    "octokit": "^4.0.2",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.9.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "@jest/globals": "^29.7.0"
  }
}
